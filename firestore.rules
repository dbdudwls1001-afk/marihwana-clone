rules_version = '2';

// marihwana-clone 크로스디바이스 동기화 보안 규칙
// 원칙: 로그인한 본인(uid) 문서만 read/write. 공개/익명 접근 전면 금지.
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자별 동기화 문서: users/{uid}
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 그 외 모든 경로 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
